import os
from dotenv import load_dotenv
load_dotenv()

os.environ["GROQ_API_KEY"]=os.getenv("GROQ_API_KEY")


from langchain.tools import tool
@tool
def get_weather(location: str) -> str:
    """get the weather at a location """
    return f"The weather at {location} is sunny with a high of 25°C."



from langchain_groq import ChatGroq

model = ChatGroq(
    model="llama-3.1-8b-instant",
    temperature=0
)
agent = create_agent(
    model = model, 
    tools=[get_weather],
   system_prompt = """
    You are a helpful assistant.
    When a tool is used, return the EXACT output from the tool.
    Do NOT modify, summarize, or add extra information.
    Do NOT add disclaimers.
    """
    )

agent


response = agent.invoke({"messages": [{"role": "user", "content": "what is the weather in Bangalore?"}]})

print(response['messages'][-1].content)


response['messages'][-1].content


 print(get_weather("Bangalore"))



